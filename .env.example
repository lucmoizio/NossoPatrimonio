# Modelo de configuração local. Copie para `.env` e preencha.
#   cp .env.example .env
# O arquivo .env é carregado automaticamente pelo app e NÃO é versionado
# (está no .gitignore). Nunca comite suas chaves.

# Chave da API da Anthropic (Consultor IA). Gere em:
#   https://console.anthropic.com/  ->  API Keys
ANTHROPIC_API_KEY=

# Opcional: sobrepõe o modelo padrão (claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6
